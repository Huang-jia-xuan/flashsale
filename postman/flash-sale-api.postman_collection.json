{
  "info": {
    "name": "Flash Sale API",
    "_postman_id": "flash-sale-collection",
    "description": "简易抢购/订单处理系统 API 测试集合",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "userId",
      "value": "1"
    }
  ],
  "item": [
    {
      "name": "商品接口",
      "item": [
        {
          "name": "查询商品列表",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products"]
            }
          }
        },
        {
          "name": "查询商品详情（缓存）",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/products/1",
              "host": ["{{baseUrl}}"],
              "path": ["api", "products", "1"]
            }
          }
        }
      ]
    },
    {
      "name": "订单接口 - 同步",
      "item": [
        {
          "name": "同步下单（正常）",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-Id", "value": "{{userId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": 1,\n  \"quantity\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders/sync",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "sync"]
            }
          }
        },
        {
          "name": "同步下单（库存不足）",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-Id", "value": "{{userId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": 2,\n  \"quantity\": 999\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders/sync",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "sync"]
            }
          }
        }
      ]
    },
    {
      "name": "订单接口 - 异步",
      "item": [
        {
          "name": "异步下单（MQ 削峰）",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-Id", "value": "{{userId}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": 2,\n  \"quantity\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"]
            }
          }
        }
      ]
    },
    {
      "name": "订单查询",
      "item": [
        {
          "name": "查询用户订单列表",
          "request": {
            "method": "GET",
            "header": [
              { "key": "X-User-Id", "value": "{{userId}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/orders",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders"]
            }
          }
        }
      ]
    },
    {
      "name": "拦截器测试",
      "item": [
        {
          "name": "未登录 - 不带 X-User-Id",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": 1,\n  \"quantity\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders/sync",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "sync"]
            }
          }
        },
        {
          "name": "用户不存在 - 无效 X-User-Id",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-Id", "value": "9999" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": 1,\n  \"quantity\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders/sync",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "sync"]
            }
          }
        }
      ]
    },
    {
      "name": "并发测试说明",
      "item": [
        {
          "name": "并发抢购测试（用 Runner 跑）",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "X-User-Id", "value": "1" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"productId\": 2,\n  \"quantity\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/orders/sync",
              "host": ["{{baseUrl}}"],
              "path": ["api", "orders", "sync"]
            },
            "description": "使用 Postman Runner 设置 20 次迭代运行此请求。商品 2（限量款球鞋）库存仅 10，预期最多生成 10 个订单，库存不为负。"
          }
        }
      ]
    }
  ]
}
